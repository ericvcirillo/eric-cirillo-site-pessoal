---
import type { Content } from "../i18n";

interface Props {
  t: Content;
  detailHref?: string;
}

const { t, detailHref } = Astro.props;
const e = t.experience;
const mono = "font-family:var(--font-mono); font-size:11px; letter-spacing:0.16em; text-transform:uppercase;";
---

<section id="experiencia" class="section">
  <div class="container section-pad" style="position:relative;">
    <span class="ghost-num" aria-hidden="true">03</span>
    <div style="position:relative; z-index:1;">
      <div
        style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:var(--text-2); margin-bottom:8px;"
      >
        {e.label}
      </div>
      {
        e.items.map((item) => (
          <div
            class="two-col"
            style="display:grid; grid-template-columns:minmax(0,180px) minmax(0,1fr); gap:clamp(20px,5vw,68px); padding:clamp(28px,3vw,38px) 0; border-top:1px solid var(--rule);"
          >
            <div style="font-family:var(--font-mono); font-size:12px; letter-spacing:0.13em; color:var(--text-2);">
              {item.date}
            </div>
            <div>
              <div style="display:flex; flex-wrap:wrap; align-items:baseline; gap:12px;">
                <h3 style="font-family:var(--font-display); font-weight:600; font-size:clamp(22px,2.4vw,30px); letter-spacing:-0.02em; margin:0; color:var(--text);">
                  {item.company}
                </h3>
                <span style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--meta);">
                  {item.role}
                </span>
              </div>
              <p style="font-size:16px; line-height:1.6; color:var(--text-2); margin:13px 0 0; max-width:64ch;">
                {item.line}
              </p>
            </div>
          </div>
        ))
      }
      {detailHref && (
        <div style="margin-top:32px;">
          <a
            href={detailHref}
            class="cta-primary lk"
            style={`${mono} color:var(--text); border:1px solid var(--rule-strong); padding:14px 22px; display:inline-flex; align-items:center; gap:10px;`}
          >
            {e.detailCta}
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      )}
    </div>
  </div>
</section>
