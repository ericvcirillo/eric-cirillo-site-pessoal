---
import type { Content, Locale } from "../i18n";
import Base from "../layouts/Base.astro";
import Header from "./Header.astro";
import Hero from "./Hero.astro";
import Stats from "./Stats.astro";
import About from "./About.astro";
import Studio from "./Studio.astro";
import Experience from "./Experience.astro";
import Skills from "./Skills.astro";
import Contact from "./Contact.astro";
import Footer from "./Footer.astro";

interface Props {
  locale: Locale;
  t: Content;
}

const { locale, t } = Astro.props;
---

<Base locale={locale} t={t}>
  <Header locale={locale} t={t} />
  <main id="main">
    <Hero t={t} locale={locale} />
    <Stats t={t} />
    <About t={t} storyHref={locale === "pt" ? "/historia" : "/en/historia"} />
    <Experience t={t} detailHref={locale === "pt" ? "/experiencia" : "/en/experiencia"} />
    <Studio t={t} caseHref={locale === "pt" ? "/studio" : "/en/studio"} />
    <Skills t={t} />
    <Contact t={t} locale={locale} />
  </main>
  <Footer t={t} />
</Base>
