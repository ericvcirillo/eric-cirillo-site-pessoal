---
import type { Content, Locale } from "../i18n";

interface Props {
  locale: Locale;
  t: Content;
  langs?: { pt: string; en: string };
}

const { locale, t, langs } = Astro.props;

const home = locale === "pt" ? "/" : "/en/";
const ptHref = langs?.pt ?? "/";
const enHref = langs?.en ?? "/en/";
const links = [
  { href: `${home}#sobre`, label: t.nav.about },
  { href: `${home}#experiencia`, label: t.nav.experience },
  { href: `${home}#studio`, label: t.nav.studio },
  { href: `${home}#contato`, label: t.nav.contact },
];

const mono =
  "font-family:var(--font-mono); font-size:11px; letter-spacing:0.18em; text-transform:uppercase;";
---

<header
  style="position:sticky; top:0; z-index:50; backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); background:var(--bg-blur); border-bottom:1px solid var(--rule);"
>
  <div
    class="container"
    style="padding-top:15px; padding-bottom:15px; display:flex; align-items:center; justify-content:space-between; gap:24px;"
  >
    <a
      href={locale === "pt" ? "/" : "/en/"}
      class="wordmark lk"
      style="font-family:var(--font-display); font-weight:600; font-size:16px; letter-spacing:-0.01em; color:var(--text);"
      >Eric Cirillo</a
    >

    <nav style="display:flex; gap:26px; align-items:center;">
      <span class="nav-links" style="display:flex; gap:26px; align-items:center;">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="nav-link lk"
              style={`${mono} color:var(--text-2);`}
            >
              {link.label}
            </a>
          ))
        }
      </span>

      <span style="width:1px; height:14px; background:var(--rule-strong);"></span>

      <span style="display:flex; gap:7px; align-items:center;">
        <a
          href={ptHref}
          hreflang="pt-BR"
          aria-label="Português"
          style={`font-family:var(--font-mono); font-size:11px; letter-spacing:0.1em; padding:2px; color:${locale === "pt" ? "var(--text)" : "var(--meta)"};`}
          >PT</a
        >
        <span style="font-family:var(--font-mono); font-size:11px; color:var(--meta);">/</span>
        <a
          href={enHref}
          hreflang="en"
          aria-label="English"
          style={`font-family:var(--font-mono); font-size:11px; letter-spacing:0.1em; padding:2px; color:${locale === "en" ? "var(--text)" : "var(--meta)"};`}
          >EN</a
        >
      </span>

      <button
        type="button"
        data-theme-toggle
        aria-label={locale === "pt" ? "Alternar tema" : "Toggle theme"}
        class="theme-btn lk"
        style="display:flex; align-items:center; gap:7px; background:none; border:1px solid var(--rule-strong); padding:6px 11px; cursor:pointer; color:var(--text-2);"
      >
        <span
          style="width:9px; height:9px; border-radius:50%; background:var(--accent); display:inline-block;"
          aria-hidden="true"></span>
        <span
          data-theme-label
          data-to-light={t.theme.toLight}
          data-to-dark={t.theme.toDark}
          style="font-family:var(--font-mono); font-size:10px; letter-spacing:0.16em; text-transform:uppercase;"
          >{t.theme.toLight}</span
        >
      </button>
    </nav>
  </div>
</header>
